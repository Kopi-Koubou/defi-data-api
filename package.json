{
  "name": "defi-data-api",
  "version": "0.1.0",
  "description": "DeFi Data API - Real-time yields, TVL, and risk metrics",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "ingest:once": "tsx src/jobs/ingest-once.ts",
    "ingest:worker": "tsx src/jobs/ingest-worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^5.2.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.4.1",
    "@fastify/swagger-ui": "^5.2.1",
    "drizzle-orm": "^0.39.3",
    "postgres": "^3.4.5",
    "ioredis": "^5.5.0",
    "bullmq": "^5.41.2",
    "zod": "^3.24.2",
    "dotenv": "^16.4.7",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ethers": "^6.13.5",
    "@solana/web3.js": "^1.98.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3",
    "tsx": "^4.19.3",
    "drizzle-kit": "^0.30.4",
    "eslint": "^9.21.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "vitest": "^3.0.7",
    "@vitest/coverage-v8": "^3.0.7"
  }
}
