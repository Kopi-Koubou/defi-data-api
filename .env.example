# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/defi_data

# Redis (Upstash)
REDIS_URL=redis://localhost:6379

# API
PORT=3000
NODE_ENV=development
API_VERSION=v1
INGEST_INTERVAL_MS=30000
INGEST_BACKFILL_DAYS=0
INGEST_MAX_BACKFILL_POOLS=25
INGEST_BACKFILL_ON_START=false

# Auth
API_KEY_SALT=default-salt-change-in-production

# External APIs (optional for MVP)
ALCHEMY_API_KEY=
HELIUS_API_KEY=
DEFILLAMA_API_URL=https://api.llama.fi
DEFILLAMA_YIELDS_API_URL=https://yields.llama.fi
DEFILLAMA_COINS_API_URL=https://coins.llama.fi
